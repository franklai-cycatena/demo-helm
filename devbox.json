{
  "packages": [
    "kubernetes-helm@latest",
    "kubectx@latest"
  ],
  "shell": {
    "scripts": {
      "Ltest": [
        "helm lint .",
        "helm template demo-helm . > /dev/null"
      ],
      "Linit": [
        "helm install demo-helm . --namespace demo-helm --create-namespace",
        "kubens demo-helm"
      ],
      "init": [
        "helm install demo-helm https://github.com/franklai-cycatena/demo-helm/archive/main.tar.gz  --namespace demo-helm --create-namespace",
        "kubens demo-helm"
      ],
      "destroy": [
        "kubens default",
        "kubectl delete namespace demo-helm"
      ]
    }
  }
}
